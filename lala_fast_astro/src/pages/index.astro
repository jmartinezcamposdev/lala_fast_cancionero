---
import Layout from '../layouts/Layout.astro';
import SongSearch from '../components/SongSearch';
import { searchSongs, countSongs, getRandomSongs, getItemsPerPage } from '../lib/db';

const url = new URL(Astro.request.url);
const searchQuery = url.searchParams.get('search') || '';
const pageParam = parseInt(url.searchParams.get('page') || '0', 10);

let initialSongs = [];
let totalCount = 0;

if (searchQuery) {
  initialSongs = searchSongs(searchQuery, pageParam);
  totalCount = countSongs(searchQuery);
} else {
  initialSongs = getRandomSongs(getItemsPerPage());
  totalCount = countSongs('');
}

const itemsPerPage = getItemsPerPage();
---

<Layout title="Búsqueda rápida - Lala Karaoke">
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.1/dist/css/bootstrap.min.css"
    rel="stylesheet"
    integrity="sha384-iYQeCzEYFbKjA/T2uDLTpkwGzCiq6soy8tYaI1GyVh/UjpbCx/TYkiZhlZB6+fzT"
    crossorigin="anonymous"
  />
  <link
    href="https://cdn.jsdelivr.net/npm/@mdi/font@6.9.96/css/materialdesignicons.min.css"
    rel="stylesheet"
  />
  <style>
    #main-title-container {
      margin: 25px auto;
      width: fit-content;
    }
    #main-title-container > h1 {
      display: inline;
    }
    #search-container {
      width: 80%;
      margin: 0 auto 40px auto;
      display: flow-root;
    }
    #search-container > label {
      width: 100%;
      margin-bottom: 10px;
      margin-left: 15px;
    }
    #search-container > input {
      width: 80%;
      float: left;
    }
    #search-container > button {
      float: right;
      width: 15%;
      padding: 0;
      font-size: 22px;
    }
    #pagination-container nav {
      width: 88%;
      margin: 10px auto;
    }
    #pagination-container nav li {
      width: 40px;
      cursor: pointer;
    }
    #pagination-container nav li > a {
      text-align: center;
    }
    #pagination-container nav li#first-page,
    #pagination-container nav li#last-page {
      width: 45px;
    }
    #pagination-container nav li.disabled {
      cursor: default;
      opacity: 0.5;
    }
    #main-table-container {
      width: 90%;
      margin: auto;
    }
    #main-table-container table tr > *:nth-child(1) {
      width: 20%;
    }
    #main-table-container table tr > *:nth-child(2) {
      width: 40%;
    }
    #main-table-container table tr > *:nth-child(3) {
      width: 40%;
    }
  </style>

  <SongSearch
    client:load
    initialSongs={initialSongs}
    totalCount={totalCount}
    initialSearch={searchQuery}
    itemsPerPage={itemsPerPage}
  />
</Layout>
