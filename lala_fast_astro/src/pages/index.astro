---
import Layout from '../layouts/Layout.astro';
import SongSearch from '../components/SongSearch';
import { searchSongs, countSongs, getRandomSongs, getItemsPerPage } from '../lib/db';

const url = new URL(Astro.request.url);
const searchQuery = url.searchParams.get('search') || '';
const pageParam = parseInt(url.searchParams.get('page') || '0', 10);

let initialSongs = [];
let totalCount = 0;

if (searchQuery) {
  initialSongs = searchSongs(searchQuery, pageParam);
  totalCount = countSongs(searchQuery);
} else {
  initialSongs = getRandomSongs(getItemsPerPage());
  totalCount = countSongs('');
}

const itemsPerPage = getItemsPerPage();
---

<Layout title="Cancionero - Karaoke LaLa">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800;900&display=swap" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/@mdi/font@6.9.96/css/materialdesignicons.min.css" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --color-bg: #f4e8ce;
      --color-surface: #ffffff;
      --color-surface-hover: #faf3e6;
      --color-red: #c0392b;
      --color-red-table: #894449;
      --color-red-dark: #a93226;
      --color-red-light: #f5e6e3;
      --color-yellow: #d4a017;
      --color-yellow-accent: #e6b422;
      --color-yellow-bg: #fffefb;
      --color-text: #2c2c2c;
      --color-text-secondary: #6b6b6b;
      --color-text-muted: #999999;
      --color-border: #e8ddd0;
      --color-border-light: #f0e8dc;
      --radius: 14px;
      --radius-sm: 8px;
      --shadow: 0 4px 24px rgba(120, 90, 50, 0.1);
      --shadow-sm: 0 2px 8px rgba(120, 90, 50, 0.06);
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--color-bg);
      color: var(--color-text);
      min-height: 100vh;
    }

    /* ─── Top Header ─── */
    .top-header {
      background: #282828;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      padding: 1rem 2rem;
    }

    .header-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .logo-text {
      font-weight: 900;
      font-size: 1.35rem;
      color: #e63946;
      letter-spacing: -0.5px;
      text-decoration: none;
      transition: opacity 0.15s ease;
    }

    .logo-text:hover {
      opacity: 0.85;
    }

    .header-divider {
      color: rgba(255, 255, 255, 0.15);
      font-size: 1.2rem;
      user-select: none;
    }

    .subtitle-text {
      font-weight: 600;
      font-size: 1.1rem;
      color: #e0e0e0;
      letter-spacing: 2px;
      text-transform: uppercase;
      text-decoration: none;
      transition: opacity 0.15s ease;
    }

    .subtitle-text:hover {
      opacity: 0.85;
    }

    /* ─── Hero Section ─── */
    .hero-section {
      text-align: center;
      padding: 3.5rem 2rem 2.5rem;
      position: relative;
    }

    .hero-section::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 80px;
      height: 3px;
      background: linear-gradient(90deg, var(--color-red), var(--color-yellow-accent));
      border-radius: 2px;
    }

    .hero-title {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.25rem;
    }

    .hero-line {
      display: block;
      line-height: 1.1;
    }

    .hero-line-1 {
      font-size: clamp(2.2rem, 5vw, 3.5rem);
      font-weight: 900;
      color: var(--color-text);
      letter-spacing: 6px;
      text-transform: uppercase;
    }

    .hero-line-2 {
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      font-weight: 800;
      color: var(--color-yellow-accent);
      letter-spacing: 3px;
      text-transform: uppercase;
    }

    /* ─── Table Area ─── */
    .table-wrapper {
      max-width: 1100px;
      margin: 0 auto;
      padding: 2rem 2rem 4rem;
    }

    .loading-text {
      text-align: center;
      color: var(--color-text-muted);
      font-size: 1.1rem;
      padding: 3rem 0;
    }

    .table-container {
      background: var(--color-surface);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      border: 1px solid var(--color-border);
      overflow: hidden;
    }

    .table-inner {
      overflow-x: auto;
    }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    thead {
      background: var(--color-red-table);
    }

    thead tr {
      border-bottom: 2px solid var(--color-yellow-accent);
    }

    th {
      padding: 1rem 1.25rem;
      text-align: left;
      font-weight: 700;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: var(--color-yellow-bg);
      white-space: nowrap;
    }

    .col-artist {
      width: 35%;
    }

    .col-title {
      width: 45%;
    }

    .col-ref {
      width: 20%;
      text-align: center;
    }

    tbody tr {
      border-bottom: 1px solid var(--color-border-light);
      transition: background 0.15s ease;
    }

    tbody tr:hover {
      background: var(--color-surface-hover);
    }

    tbody tr:last-child {
      border-bottom: none;
    }

    td {
      padding: 0.85rem 1.25rem;
      font-size: 0.95rem;
      color: #4a4a4a;
    }

    td.col-artist {
      color: var(--color-text);
      font-weight: 600;
    }

    td.col-title {
      color: #3a3a3a;
    }

    td.col-ref {
      text-align: center;
      font-family: 'Inter', monospace;
      font-size: 0.85rem;
      color: #3a3a3a;
    }

    td.no-results-cell {
      text-align: center;
      padding: 2.5rem 1rem;
      color: var(--color-red);
      font-weight: 600;
      font-size: 1rem;
    }

    /* ─── Pagination ─── */
    .pagination-wrapper {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 0.4rem;
      margin-top: 1.5rem;
      flex-wrap: wrap;
    }

    .page-btn {
      background: var(--color-surface);
      color: var(--color-text-secondary);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-sm);
      padding: 0.5rem 0.85rem;
      font-size: 0.85rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.15s ease;
      font-family: inherit;
      min-width: 38px;
    }

    .page-btn:hover:not(:disabled) {
      background: var(--color-surface-hover);
      color: var(--color-text);
      border-color: var(--color-border);
    }

    .page-btn:disabled {
      opacity: 0.3;
      cursor: not-allowed;
    }

    .page-btn-active {
      background: var(--color-red);
      color: #ffffff;
      border-color: var(--color-red);
    }

    .page-btn-active:hover {
      background: var(--color-red-dark);
      border-color: var(--color-red-dark);
    }

    /* ─── Search Bar ─── */
    .search-bar {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      max-width: 400px;
      margin: 0 20px 1rem auto;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-sm);
      overflow: hidden;
      transition: border-color 0.2s ease;
      box-shadow: var(--shadow-sm);
    }

    .search-bar:focus-within {
      border-color: var(--color-red);
    }

    .search-bar input {
      background: transparent;
      border: none;
      outline: none;
      color: var(--color-text);
      padding: 0.7rem 1rem;
      font-size: 0.95rem;
      flex: 1;
      font-family: inherit;
    }

    .search-bar input::placeholder {
      color: var(--color-text-muted);
    }

    .search-bar button {
      background: var(--color-red);
      border: none;
      color: #ffffff;
      padding: 0.7rem 1rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.15s ease;
    }

    .search-bar button:hover {
      background: var(--color-red-dark);
    }

    .search-bar button i {
      font-size: 1.15rem;
    }

    /* ─── Responsive ── */
    @media (max-width: 640px) {
      .top-header {
        padding: 0.75rem 1rem;
      }

      .logo-text {
        font-size: 1.1rem;
      }

      .subtitle-text {
        font-size: 0.85rem;
      }

      .hero-section {
        padding: 2.5rem 1rem 2rem;
      }

      .table-wrapper {
        padding: 1.5rem 1rem 3rem;
      }

      .search-bar {
        max-width: 100%;
        margin: 0 0 1rem;
      }

      .search-bar input {
        width: 100%;
      }
    }
  </style>

  <SongSearch
    client:load
    initialSongs={initialSongs}
    totalCount={totalCount}
    initialSearch={searchQuery}
    itemsPerPage={itemsPerPage}
  />
</Layout>
